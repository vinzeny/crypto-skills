{
  "name": "@byreal-io/byreal-cli",
  "version": "0.3.4",
  "description": "AI-native CLI for Byreal CLMM DEX on Solana",
  "type": "module",
  "main": "dist/index.cjs",
  "bin": {
    "byreal-cli": "dist/index.cjs"
  },
  "homepage": "https://github.com/byreal-git/byreal-agent-skills",
  "repository": {
    "type": "git",
    "url": "https://github.com/byreal-git/byreal-agent-skills.git"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "postversion": "npm publish && git push && git push --tags"
  },
  "keywords": [
    "byreal",
    "solana",
    "clmm",
    "dex",
    "cli",
    "defi",
    "liquidity"
  ],
  "author": "Byreal Team (https://github.com/byreal-git)",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/index.cjs",
    "skills/"
  ],
  "devDependencies": {
    "@coral-xyz/anchor": "0.31.1",
    "@solana/buffer-layout": "4.0.1",
    "@solana/spl-memo": "0.2.5",
    "@solana/spl-token": "0.4.13",
    "@solana/web3.js": "1.98.4",
    "@types/bn.js": "5.2.0",
    "@types/node": "20.19.35",
    "bn.js": "5.2.3",
    "bs58": "6.0.0",
    "chalk": "5.6.2",
    "cli-table3": "0.6.5",
    "commander": "12.1.0",
    "decimal.js": "10.6.0",
    "dotenv": "16.6.1",
    "esbuild": "0.24.2",
    "eslint": "9.39.3",
    "ky": "1.14.3",
    "lodash-es": "4.17.23",
    "prettier": "3.8.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  },
  "dependencies": {
    "@byreal-io/byreal-clmm-sdk": "^0.2.2"
  }
}
